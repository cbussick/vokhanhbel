{
  "name": "vokhanhbel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:full": "docker compose up -d --wait postgres && npm run db:migrate && node --env-file=.env.local node_modules/.bin/vercel dev --local --listen 3000",
    "dev:e2e": "node --env-file=.env.local node_modules/.bin/vercel dev --local --listen 4173",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "vitest run --config vitest.database.config.ts",
    "test:e2e": "playwright test",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "node --experimental-strip-types scripts/setupEnvironment.ts",
    "password:hash": "node --experimental-strip-types scripts/hashPassword.ts",
    "licenses": "node --experimental-strip-types scripts/checkLicenses.ts",
    "db:generate": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:production": "node --experimental-strip-types scripts/migrateProduction.ts",
    "db:restore:verify": "node --experimental-strip-types scripts/verifyRestore.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "drizzle-orm": "^0.45.2",
    "i18next": "^26.3.6",
    "openai": "^6.46.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/core": "^7.29.7",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/router-plugin": "^1.168.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vercel": "^56.2.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
